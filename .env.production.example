# Runtime
FLASK_ENV=production
PORT=8000
LOG_LEVEL=INFO

# Frontend allowed origins
CORS_ORIGINS=https://seu-dominio.com

# Firebase / GCP
FIREBASE_PROJECT_ID=brain-sync-app
GOOGLE_CLOUD_PROJECT=brain-sync-app
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json
# Optional alternativa: JSON da service account em uma linha (sem arquivo)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional Gemini settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
